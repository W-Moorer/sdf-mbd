{
  "suite": "paper_examples_sparse_sdf_contact_force_dynamics",
  "description": "Locked paper examples for OpenVDB sparse narrow-band SDF plus field-contact force dynamics regression.",
  "runner": "paper_examples_openvdb.cpp",
  "output_dir": "out/paper_example_dynamic_benchmarks",
  "outputs": [
    "sparse_sdf_frames.csv",
    "comparison_summary.csv",
    "timing_summary.csv",
    "../../paper_example/figures/eccentric_roller_curves.pdf",
    "../../paper_example/figures/headon_spheres_curves.pdf",
    "../../paper_example/figures/headon_spheres_mass_ratio_curves.pdf",
    "../../paper_example/figures/simple_gear_curves.pdf"
  ],
  "cases": [
    {
      "name": "eccentric_roller",
      "kind": "cam_follower",
      "model": "cases/eccentric_roller/eccentric_roller_model.json",
      "models": [
        "cases/eccentric_roller/models/eccentric_disk_cam.obj",
        "cases/eccentric_roller/models/roller_follower.obj"
      ],
      "checks": [
        {
          "quantity": "follower_y",
          "tolerance": 0.0006
        }
      ]
    },
    {
      "name": "headon_spheres",
      "kind": "headon_spheres",
      "model": "cases/headon_spheres/headon_spheres_model.json",
      "models": [
        "cases/headon_spheres/models/ball_sphere.obj"
      ],
      "checks": [
        {
          "quantity": "sphere_a_x",
          "tolerance": 0.002
        },
        {
          "quantity": "sphere_b_x",
          "tolerance": 0.002
        },
        {
          "quantity": "sphere_a_vx",
          "tolerance": 0.05
        },
        {
          "quantity": "sphere_b_vx",
          "tolerance": 0.05
        }
      ]
    },
    {
      "name": "headon_spheres_mass_ratio",
      "kind": "headon_spheres",
      "model": "cases/headon_spheres_mass_ratio/headon_spheres_mass_ratio_model.json",
      "models": [
        "cases/headon_spheres_mass_ratio/models/ball_sphere.obj"
      ],
      "checks": [
        {
          "quantity": "sphere_a_x",
          "tolerance": 0.002
        },
        {
          "quantity": "sphere_b_x",
          "tolerance": 0.002
        },
        {
          "quantity": "sphere_a_vx",
          "tolerance": 0.05
        },
        {
          "quantity": "sphere_b_vx",
          "tolerance": 0.05
        }
      ]
    },
    {
      "name": "simple_gear",
      "kind": "simple_gear",
      "model": "cases/simple_gear/simple_gear_model.json",
      "models": [
        "cases/simple_gear/simple gear.rmd",
        "cases/simple_gear/models/gear_21.obj",
        "cases/simple_gear/models/gear_22.obj",
        "cases/simple_gear/data/Gear22.csv"
      ],
      "checks": [
        {
          "quantity": "gear22_rx_final",
          "tolerance": 0.02
        },
        {
          "quantity": "gear22_rx_rms_t_ge_0p02",
          "tolerance": 0.09
        },
        {
          "quantity": "gear22_rx_max_jump_t_ge_0p02",
          "tolerance": 0.15
        }
      ]
    }
  ]
}
